# CortexOS – Backend Environment Configuration
# Copy to .env and fill in values
#
# Authentication: Uses Google Application Default Credentials (ADC).
# On local dev: set GOOGLE_APPLICATION_CREDENTIALS to a service account key JSON.
# On Cloud Run: ADC is automatic via the attached service account.
# NO API KEYS – all auth flows through OAuth2 Bearer tokens.

# ── Vertex AI Configuration ──────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
GEMINI_MODEL_NAME=gemini-2.0-flash-live

# Path to Google Cloud service account key JSON (local dev only; not needed on Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set to true to run without GCP credentials (uses mock Gemini client)
DEMO_MODE=false

# ── Playwright Configuration ─────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# ── Screen Capture ───────────────────────────────────────────────────────────
SCREEN_CAPTURE_INTERVAL_MS=2500
SCREEN_CAPTURE_QUALITY=60
SCREEN_CAPTURE_MAX_WIDTH=1024

# ── Safety ───────────────────────────────────────────────────────────────────
MAX_ACTIONS_PER_MINUTE=30
TOOL_EXECUTION_TIMEOUT_MS=10000
